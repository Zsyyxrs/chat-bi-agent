# === 通义千问 (DashScope) ===
# 申请地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Langfuse Self-hosted (bundled in docker-compose) ===
# 启动 docker-compose 后在 http://localhost:3001 用 admin@chatbi.local / admin12345 登录
# 进入 Settings → API Keys 创建一对 key 填到下面
# （主机端口 3001，避开常被外部 Langfuse 占用的 3000）
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_HOST=http://localhost:3001

# === PostgreSQL ===
PG_HOST=localhost
# 主机端口 5433（5432 留给可能并存的 Langfuse PG）；容器内仍为 5432
PG_PORT=5433
PG_DATABASE=chatbi

# 写入用（已有数据生成会用，给 seed 脚本）
PG_USER=chatbi
PG_PASSWORD=chatbi_dev

# 只读用（Agent SQL 执行用，Phase 1 任务 1.3 创建）
PG_READONLY_USER=chatbi_readonly
PG_READONLY_PASSWORD=readonly_dev
